# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# CRM Configuration (HubSpot or ConvertKit)
# Uncomment the one you're using
HUBSPOT_API_KEY=your-hubspot-api-key-here
# CONVERTKIT_API_KEY=your-convertkit-key-here

# Stripe Configuration (optional — leave empty or comment out if not using Stripe)
# STRIPE_API_KEY=sk_test_your-stripe-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Email Configuration
SENDER_EMAIL=no-reply@example.com
SENDER_NAME=OHM Team

# Gmail Configuration (for SMTP sending)
GMAIL_EMAIL=your-gmail@example.com
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (if using local persistence)
# DATABASE_URL=sqlite:///./email_agent.db
