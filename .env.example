# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-your-api-key-here

# CRM Configuration (HubSpot or ConvertKit)
# Uncomment the one you're using
HUBSPOT_API_KEY=your-hubspot-key-here
# CONVERTKIT_API_KEY=your-convertkit-key-here

# Stripe Configuration (for webhook data)
